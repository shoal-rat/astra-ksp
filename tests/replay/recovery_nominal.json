    {"body": "Kerbin", "altitude": 32000, "surface_speed": 900,  "chutes_deployed": false, "situation": "Vessel.Situation.flying"},
    {"body": "Kerbin", "altitude": 9000,  "surface_speed": 320,  "chutes_deployed": false, "situation": "Vessel.Situation.flying"},
    {"body": "Kerbin", "altitude": 4200,  "surface_speed": 210,  "chutes_deployed": false, "situation": "Vessel.Situation.flying"},
    {"body": "Kerbin", "altitude": 1500,  "surface_speed": 70,   "chutes_deployed": true,  "situation": "Vessel.Situation.flying"},
    {"body": "Kerbin", "altitude": 200,   "surface_speed": 8,    "chutes_deployed": true,  "situation": "Vessel.Situation.flying"},
    {"body": "Kerbin", "altitude": 0,     "surface_speed": 4,    "chutes_deployed": true,  "situation": "Vessel.Situation.landed"},
    {"body": "Kerbin", "altitude": 0,     "surface_speed": 0,    "chutes_deployed": true,  "situation": "Vessel.Situation.recovered"}
  ]
