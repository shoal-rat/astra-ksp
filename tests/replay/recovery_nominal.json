{
  "machine": "recovery",
  "description": "Kerbin reentry + recovery: hypersonic entry (chutes stay stowed while fast/high) -> chutes deploy ONLY once safe (<250 m/s AND <5 km) -> touchdown (landed) -> recovered to the space centre (RECOVERED). Asserts chutes never arm above the safe gate.",
  "params": {"chute_safe_speed_mps": 250.0, "chute_safe_alt_m": 5000.0},
  "expect": "RECOVERED",
  "ticks": [
